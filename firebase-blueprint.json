{
  "entities": {
    "Score": {
      "title": "Score",
      "description": "A leaderboard score entry",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The player's name"
        },
        "wpm": {
          "type": "number",
          "description": "Words per minute"
        },
        "errorCount": {
          "type": "number",
          "description": "Number of typing errors"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the score was achieved"
        },
        "avatar": {
          "type": "string",
          "description": "The avatar selected"
        },
        "language": {
          "type": "string",
          "description": "Selected language code (mn or en)"
        }
      },
      "required": ["name", "wpm", "errorCount", "createdAt", "avatar", "language"]
    }
  },
  "firestore": {
    "/typeracer_scores/{scoreId}": {
      "schema": "Score",
      "description": "Collection of typeracer scores for leaderboard"
    }
  }
}
